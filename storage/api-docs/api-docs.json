{
    "openapi": "3.0.0",
    "info": {
        "title": "Auction Platform API",
        "description": "Public REST API for auction platform integration.",
        "contact": {
            "email": "api@example.com"
        },
        "version": "1.0.0"
    },
    "paths": {
        "/api/v1/auctions": {
            "get": {
                "tags": [
                    "Auctions"
                ],
                "summary": "List active auctions",
                "operationId": "999974a75bacd75345d926a7ec7d84ba",
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "description": "Search keyword",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "category_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max_price",
                        "in": "query",
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "sort",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "ending_soon",
                                "newest",
                                "price_asc",
                                "price_desc"
                            ]
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "maximum": 50
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated auction list",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuctionCollection"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/auctions/{auction}": {
            "get": {
                "tags": [
                    "Auctions"
                ],
                "summary": "Get auction details",
                "operationId": "58cf098816e90e19984331d41e4f36a6",
                "parameters": [
                    {
                        "name": "auction",
                        "in": "path",
                        "description": "Auction ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Auction details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AuctionResource"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        },
        "/api/v1/auth/token": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Create new API token",
                "operationId": "91fabd5c5e0f3fff64ee77e8110689c7",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "email",
                                    "password",
                                    "device_name"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password"
                                    },
                                    "device_name": {
                                        "type": "string"
                                    },
                                    "abilities": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token generated",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "token": {
                                            "type": "string"
                                        },
                                        "token_type": {
                                            "type": "string",
                                            "example": "Bearer"
                                        },
                                        "abilities": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error"
                    }
                }
            }
        },
        "/api/v1/auth/revoke": {
            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Revoke current API token",
                "operationId": "71e34edaff82485f03607c2630f5e141",
                "responses": {
                    "200": {
                        "description": "Token revoked"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/auctions/{auction}/bids": {
            "get": {
                "tags": [
                    "Bids"
                ],
                "summary": "List bids for an auction",
                "operationId": "69bfa59678f3cf915576665260185030",
                "parameters": [
                    {
                        "name": "auction",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of bids"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            },
            "post": {
                "tags": [
                    "Bids"
                ],
                "summary": "Place a bid",
                "operationId": "7c9c4c00f12a057327cc2dd917cd6328",
                "parameters": [
                    {
                        "name": "auction",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "amount"
                                ],
                                "properties": {
                                    "amount": {
                                        "type": "number"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Bid placed successfully"
                    },
                    "400": {
                        "description": "Validation Error"
                    },
                    "422": {
                        "description": "Unprocessable Entity"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/categories": {
            "get": {
                "tags": [
                    "Categories"
                ],
                "summary": "List categories",
                "operationId": "e225c2b7eb5daf7fb16e00f4f07ff030",
                "parameters": [
                    {
                        "name": "parent_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "maximum": 50
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Paginated category list"
                    }
                }
            }
        },
        "/api/v1/categories/{category}": {
            "get": {
                "tags": [
                    "Categories"
                ],
                "summary": "Get category details",
                "operationId": "d5023633bd2ab475b5f7d3fe21113fd9",
                "parameters": [
                    {
                        "name": "category",
                        "in": "path",
                        "description": "Category ID",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Category details"
                    },
                    "404": {
                        "description": "Not Found"
                    }
                }
            }
        },
        "/api/v1/profile": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Get user profile",
                "operationId": "dffac35700b3186de8d19cc212fe0285",
                "responses": {
                    "200": {
                        "description": "User Profile"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/profile/bids": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Get user bids",
                "operationId": "fed439482ecd2276661891fe58fb0238",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User Bids"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/profile/wallet": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Get user wallet details",
                "operationId": "b6b624f7befaed815ae7e749dc426f20",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User Wallet"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/profile/notifications": {
            "get": {
                "tags": [
                    "Profile"
                ],
                "summary": "Get user notifications",
                "operationId": "3af5f1f3bc01e0354fe4ab76ffb4a5cc",
                "parameters": [
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User Notifications"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/api/v1/auctions/{auction}/watch": {
            "post": {
                "tags": [
                    "Watchlist"
                ],
                "summary": "Toggle watch status for an auction",
                "operationId": "fc2082b3554821dbfba8507f667d463d",
                "parameters": [
                    {
                        "name": "auction",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "outbid_threshold": {
                                        "type": "number",
                                        "nullable": true
                                    },
                                    "price_alert_at": {
                                        "type": "number",
                                        "nullable": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Watchlist status toggled or updated"
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ErrorResponse": {
                "properties": {
                    "error": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "message": {
                        "type": "string"
                    },
                    "details": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "AuctionResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "status": {
                        "type": "string"
                    },
                    "current_price": {
                        "type": "number"
                    },
                    "starting_price": {
                        "type": "number"
                    },
                    "reserve_met": {
                        "type": "boolean"
                    },
                    "reserve_price": {
                        "type": "number",
                        "nullable": true
                    },
                    "min_bid_increment": {
                        "type": "number"
                    },
                    "next_minimum_bid": {
                        "type": "number"
                    },
                    "bid_count": {
                        "type": "integer"
                    },
                    "currency": {
                        "type": "string"
                    },
                    "condition": {
                        "type": "string"
                    },
                    "condition_label": {
                        "type": "string"
                    },
                    "end_time": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "time_remaining": {
                        "type": "string"
                    },
                    "seller": {
                        "type": "object"
                    },
                    "brand": {
                        "type": "object",
                        "nullable": true
                    },
                    "categories": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    },
                    "images": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "links": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "AuctionCollection": {
                "properties": {
                    "data": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/AuctionResource"
                        }
                    },
                    "links": {
                        "type": "object"
                    },
                    "meta": {
                        "type": "object"
                    }
                },
                "type": "object"
            },
            "BidResource": {
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "auction_id": {
                        "type": "integer"
                    },
                    "amount": {
                        "type": "number"
                    },
                    "bid_type": {
                        "type": "string"
                    },
                    "is_snipe_bid": {
                        "type": "boolean"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "auction": {
                        "type": "object",
                        "nullable": true
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "Token",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Auctions",
            "description": "Auctions"
        },
        {
            "name": "Authentication",
            "description": "Authentication"
        },
        {
            "name": "Bids",
            "description": "Bids"
        },
        {
            "name": "Categories",
            "description": "Categories"
        },
        {
            "name": "Profile",
            "description": "Profile"
        },
        {
            "name": "Watchlist",
            "description": "Watchlist"
        }
    ]
}